generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "cloudflare"
}

datasource db {
  provider = "sqlite"
}

/// Custom table — uses @map directives for snake_case columns.
model Task {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String
  description String
  completed   Boolean
  dueDate     DateTime @map("due_date")

  @@map("tasks")
}
