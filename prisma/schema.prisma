// NOTE: All column names use snake_case via @map directives for consistency

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "cloudflare"
}

datasource db {
  provider = "sqlite"
}

model FlagDefinition {
  key           String   @id @map("key")
  name          String
  description   String?  @map("description")
  type          String   @default("boolean") @map("type")
  defaultValue  String   @map("default_value")
  enabled       Boolean  @default(true) @map("enabled")
  environments  String?  @map("environments")
  targeting     String?  @map("targeting")
  tags          String?  @map("tags")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("flag_definitions")
}
